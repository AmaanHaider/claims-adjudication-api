    {
      "name": "Claims",
      "item": [
        {
          "name": "POST /claims - partially approved",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('status is 201', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const data = pm.response.json();",
                  "pm.collectionVariables.set('claimId', String(data.id));",
                  "if (data.ClaimLineItems && data.ClaimLineItems[0]) {",
                  "  pm.collectionVariables.set('lineItemId', String(data.ClaimLineItems[0].id));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"memberId\": {{memberId}},\n  \"providerName\": \"City Health Clinic\",\n  \"diagnosisCodes\": [\"M54.5\"],\n  \"lineItems\": [\n    { \"serviceType\": \"primary_care\", \"amountCents\": 20000, \"dateOfService\": \"2026-04-10\" },\n    { \"serviceType\": \"dental\", \"amountCents\": 15000, \"dateOfService\": \"2026-04-10\" }\n  ]\n}"
            },
